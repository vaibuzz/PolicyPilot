# ---- Primary LLM: Anthropic Claude (claude-sonnet-4-5) ----
# ANTHROPIC_API_KEY is the primary LLM key. Set this for best extraction quality.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ---- Fallback LLM: Groq (llama-3.3-70b-versatile) ----
# GROQ_API_KEY is the fallback. Used automatically if Anthropic fails or is not set.
# Get your key at https://console.groq.com/
GROQ_API_KEY=""

# ---- Email (Gmail SMTP for report delivery) ----
GMAIL_ADDRESS=""
GMAIL_APP_PASSWORD=""

# ---- Frontend URL (for CORS) ----
FRONTEND_URL=http://localhost:5173

# ---- Extraction caching (set to "true" to cache LLM responses to disk) ----
# File cache: writes backend/cache/extraction_<hash>.json per document.
# This is the FALLBACK layer — the primary cache is always-on SQLite (see below).
SAVE_EXTRACTION_CACHE=true

# ---- SQLite extraction cache (always-on, zero setup required) ----
# The DB lives at backend/db/policy_cache.db and is created automatically.
# Stores both the RAW LLM output strings (before normalization) and the
# processed ExtractionResponse. No configuration needed.
#
# Cache priority when /extract-rules is called:
#   1. SQLite DB  (backend/db/policy_cache.db)  — checked first, always active
#   2. File cache (backend/cache/*.json)         — fallback, needs SAVE_EXTRACTION_CACHE=true
#   3. Live LLM calls                            — only when both caches miss
#
# To inspect the cache: GET /cached-policies
# To bust a single entry: DELETE /cached-policies/<doc_hash>
